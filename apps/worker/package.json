{
  "name": "@profit-guard/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "run:once": "WORKER_RUN_ONCE=true tsx src/index.ts",
    "seed:real-store": "tsx src/scripts/seed-real-store.ts",
    "smoke:email": "tsx src/scripts/smoke-email-delivery.ts",
    "smoke:alerts": "tsx src/scripts/smoke-alert-engine.ts",
    "smoke:backfill": "tsx src/scripts/smoke-backfill-pipeline.ts",
    "test": "tsx --test src/**/*.test.ts",
    "build": "tsup src/index.ts --format esm --target node22 --out-dir dist --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
