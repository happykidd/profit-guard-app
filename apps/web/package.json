{
  "name": "@profit-guard/web",
  "private": true,
  "scripts": {
    "build": "pnpm --dir ../.. db:generate && react-router build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "pnpm run setup && pnpm run start",
    "setup": "pnpm --dir ../.. db:generate",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "tsx --test app/**/*.test.ts",
    "smoke:alert-lifecycle": "tsx app/scripts/smoke-alert-lifecycle.ts",
    "smoke:cost-batches": "tsx app/scripts/smoke-cost-batches.ts",
    "smoke:costs": "tsx app/scripts/smoke-cost-import.ts",
    "smoke:fallback-rules": "tsx app/scripts/smoke-fallback-rule-import.ts",
    "smoke:reports": "tsx app/scripts/smoke-reports.ts",
    "smoke:settings-lifecycle": "tsx app/scripts/smoke-settings-lifecycle.ts",
    "smoke:supplier-contract-batches": "tsx app/scripts/smoke-supplier-contract-batches.ts",
    "smoke:supplier-contracts": "tsx app/scripts/smoke-supplier-contracts.ts",
    "shopify": "shopify",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "pnpm --dir ../.. db:generate && react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.31",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  }
