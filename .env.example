DATABASE_URL="postgresql://postgres:postgres@localhost:5432/profit_guard?schema=public"
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL=""
SCOPES="read_orders,write_orders,read_products,write_products,read_inventory"
SHOP_CUSTOM_DOMAIN=""
NODE_ENV="development"
REQUIRE_DATABASE="false"
WORKER_POLL_INTERVAL_MS="5000"
WORKER_RUN_ONCE="false"
BILLING_TEST_MODE="true"
SHOPIFY_BILLING_MODE="managed"
SHOPIFY_MANAGED_PRICING_APP_HANDLE="profit-guard-22"
PROFIT_GUARD_BILLING_CURRENCY="USD"
PROFIT_GUARD_STARTER_PRICE="29"
PROFIT_GUARD_GROWTH_PRICE="79"
PROFIT_GUARD_TRIAL_DAYS="14"
PROFIT_GUARD_SUPPORT_EMAIL="support@example.com"
#
# Resend email delivery:
# 1. Set PROFIT_GUARD_EMAIL_PROVIDER to "resend"
# 2. Set PROFIT_GUARD_EMAIL_FROM to a sender on your verified Resend domain
# 3. Paste your RESEND_API_KEY below
# 4. Run `pnpm test:smoke:email -- --to you@example.com` to verify delivery
PROFIT_GUARD_EMAIL_PROVIDER="disabled"
PROFIT_GUARD_EMAIL_FROM="Profit Guard <noreply@mail.yourdomain.com>"
PROFIT_GUARD_AI_PROVIDER="disabled"
PROFIT_GUARD_OPENAI_MODEL="gpt-4.1-mini"
PROFIT_GUARD_OPENAI_BASE_URL="https://api.openai.com/v1"
PROFIT_GUARD_OPENROUTER_MODEL="openai/gpt-4.1-mini"
PROFIT_GUARD_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
PROFIT_GUARD_OPENROUTER_APP_TITLE="Profit Guard"
PROFIT_GUARD_ENABLE_DIGEST_SCHEDULER="false"
WORKER_DIGEST_INTERVAL_MS="60000"
WORKER_DIGEST_DELIVERY_LIMIT="20"
RESEND_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
PROFIT_GUARD_RESEND_BASE_URL="https://api.resend.com"
